# ── Backend ───────────────────────────────────────────────
DATABASE_URL=postgres://seguro:seguro@localhost:5432/seguro
PORT=8080
RUST_LOG=info
# ── Аутентификация менеджера (JWT, Волна 3) ───────────────
# Секрет подписи JWT (HS256). Сгенерируйте длинный случайный, напр.:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret
# Argon2-хэш пароля менеджера (пароль в открытом виде НЕ храним). Сгенерируйте:
#   cargo run --bin hash_password -- 'ВашСложныйПароль'
# и вставьте полученную PHC-строку (начинается с $argon2id$...).
MANAGER_PASSWORD_HASH=$argon2id$v=19$m=19456,t=2,p=1$change$me
# Время жизни токенов
ACCESS_TTL_MIN=30
REFRESH_TTL_DAYS=7
# Флаг Secure на refresh-cookie: true в проде (HTTPS), false локально (HTTP)
COOKIE_SECURE=false
# CORS: домены фронтенда через запятую, либо * на время разработки.
# Для работы cookie-логина укажите конкретный домен (не *).
ALLOWED_ORIGINS=http://localhost:5173
# Лимит запросов с одного IP в минуту
RATE_LIMIT_PER_MIN=60

# ── Postgres (для docker-compose) ─────────────────────────
POSTGRES_USER=seguro
POSTGRES_PASSWORD=seguro
POSTGRES_DB=seguro
