# ── Backend ───────────────────────────────────────────────
DATABASE_URL=postgres://seguro:seguro@localhost:5432/seguro
PORT=8080
RUST_LOG=info
# Токен для доступа менеджера к GET /api/leads. Сгенерируйте длинный случайный.
ADMIN_API_TOKEN=change-me-to-a-long-random-secret
# CORS: домены фронтенда через запятую, либо * на время разработки
ALLOWED_ORIGINS=http://localhost:5173
# Лимит запросов с одного IP в минуту
RATE_LIMIT_PER_MIN=60

# ── Postgres (для docker-compose) ─────────────────────────
POSTGRES_USER=seguro
POSTGRES_PASSWORD=seguro
POSTGRES_DB=seguro
