# ── Frontend (Vite) ───────────────────────────────────────
# Базовый URL backend REST API. Если не задан — используется http://localhost:8080.
# Vite пробрасывает в бандл только переменные с префиксом VITE_.
# Скопируйте в apps/web/.env.local и apps/admin/.env.local при необходимости.
VITE_API_URL=http://localhost:8080
