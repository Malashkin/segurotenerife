# ── Frontend ──────────────────────────────────────────────
# Базовый URL backend REST API. Если не задан — используется http://localhost:8080.
# admin (Vite) читает VITE_*; web-astro (Astro) — PUBLIC_* и VITE_* (см. envPrefix).
# Скопируйте в apps/admin/.env.local и apps/web-astro/.env при необходимости.
VITE_API_URL=http://localhost:8080
PUBLIC_API_URL=http://localhost:8080

# ── PostHog (продуктовая аналитика) ───────────────────────
# ПУБЛИЧНЫЙ проектный ключ phc_… (Project Settings → Project API Key). Он
# write-only и безопасен в клиентском бандле. НЕ используйте персональный ключ
# phx_… — он секретный и в клиент попадать не должен.
# Без ключа аналитика выключена (тихий no-op).
# web-astro:
PUBLIC_POSTHOG_KEY=phc_xxx
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# admin:
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://eu.i.posthog.com
