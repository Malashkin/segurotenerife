{
  "name": "seguro-tenerife-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Seguro Tenerife frontend monorepo (pnpm workspaces + Feature-Sliced Design)",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev:web": "pnpm --filter @seguro/web-astro dev",
    "dev:admin": "pnpm --filter @seguro/admin dev",
    "build": "pnpm --filter @seguro/web-astro build && pnpm --filter @seguro/admin build",
    "build:web": "pnpm --filter @seguro/web-astro build",
    "build:admin": "pnpm --filter @seguro/admin build",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "jsdom": "^29.1.1",
    "typescript": "5.6.3",
    "vite-tsconfig-paths": "5.0.1",
    "vitest": "^4.1.9"
  }
}
