---
/** «О нас» на локалях с префиксом: /uk|en|es/about/ */
import AboutPage from '../../../components/AboutPage.astro';
import type { AppLocale } from '@shared/i18n';

export function getStaticPaths() {
  return (['en', 'es', 'uk'] as AppLocale[]).map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: AppLocale };
---

<AboutPage locale={locale} />
