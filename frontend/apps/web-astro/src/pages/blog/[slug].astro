---
/** Статьи блога на русском (каноническая локаль, без префикса): /blog/<slug>. */
import { getCollection } from 'astro:content';
import ArticlePage from '../../components/ArticlePage.astro';

export async function getStaticPaths() {
  const arts = await getCollection('articles', (a) => a.data.locale === 'ru');
  return arts.map((entry) => ({ params: { slug: entry.data.urlSlug }, props: { entry } }));
}

const { entry } = Astro.props;
---

<ArticlePage entry={entry} />
