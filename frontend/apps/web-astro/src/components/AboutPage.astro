---
/** Страница «О нас»: /about/ (ru) и /<locale>/about/. E-E-A-T-сигнал доверия. */
import Layout from '../layouts/Layout.astro';
import NavBar from './NavBar.astro';
import Footer from './Footer.astro';
import Overlays from '../islands/Overlays.tsx';
import { getT } from '../i18n/t';
import { ABOUT } from '../i18n/about';
import type { AppLocale } from '@shared/i18n';

const { locale } = Astro.props as { locale: AppLocale };
const t = getT(locale);
const a = ABOUT[locale];

const LOCALES: AppLocale[] = ['ru', 'en', 'es', 'uk'];
const aboutPath = (l: string) => (l === 'ru' ? '/about/' : `/${l}/about/`);
const canonical = new URL(aboutPath(locale), Astro.site).href;
const homeHref = locale === 'ru' ? Astro.site!.href : new URL(`/${locale}/`, Astro.site).href;
const alternates = LOCALES.map((l) => ({ hreflang: l, href: new URL(aboutPath(l), Astro.site).href }));

const breadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Seguro Tenerife', item: homeHref },
    { '@type': 'ListItem', position: 2, name: a.h1, item: canonical },
  ],
};
---

<Layout
  locale={locale}
  title={a.title}
  description={a.description}
  keywords={a.keywords}
  canonicalUrl={canonical}
  includeSiteFaq={false}
  extraSchema={[breadcrumb]}
  alternates={alternates}
>
  <div id="top">
    <NavBar locale={locale} />
    <main class="bg-white">
      <article class="mx-auto w-[min(760px,calc(100vw-40px))] py-12">
        <h1 class="font-heading text-[2rem] font-bold leading-tight text-ink sm:text-[2.4rem]">
          {a.h1}
        </h1>
        <p class="mt-3 text-[1.05rem] leading-relaxed text-muted">{a.lead}</p>

        <div class="mt-8 flex flex-col gap-6">
          {
            a.blocks.map((b) => (
              <section>
                <h2 class="font-heading text-[1.3rem] font-bold text-ink">{b.h}</h2>
                <p class="mt-1.5 text-[0.98rem] leading-relaxed text-ink/80">{b.p}</p>
              </section>
            ))
          }
        </div>

        <aside class="mt-10 rounded-2xl bg-gradient-to-br from-brand-dark to-brand p-6 text-white">
          <h2 class="font-heading text-[1.25rem] font-bold">{t('art_cta_h')}</h2>
          <p class="mt-1.5 text-[0.95rem] opacity-90">{t('art_cta_p')}</p>
          <button
            type="button"
            data-ui="open-chat"
            class="mt-4 inline-flex items-center gap-2 rounded-xl bg-white px-5 py-3 text-[0.95rem] font-semibold text-brand-dark transition-transform hover:scale-[1.02]"
          >
            {t('art_cta_btn')}
          </button>
        </aside>
      </article>
    </main>
    <Footer locale={locale} />
  </div>
  <Overlays client:only="react" locale={locale} />
</Layout>
