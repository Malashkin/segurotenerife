---
/**
 * Страница статьи блога: Layout (SEO-head + Article/Breadcrumb/FAQ schema) +
 * шапка/подвал/чат лендинга + рендер Markdown. URL: /blog/<slug> (ru),
 * /<locale>/blog/<slug> (uk/en/es). hreflang — на переводы той же статьи.
 */
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import NavBar from './NavBar.astro';
import Footer from './Footer.astro';
import Overlays from '../islands/Overlays.tsx';
import { getT } from '../i18n/t';
import type { AppLocale } from '@shared/i18n';

interface Props {
  entry: CollectionEntry<'articles'>;
}
const { entry } = Astro.props;
const { locale, urlSlug: slug, title, description, keywords, tag, date, updated, faq } = entry.data;
const t = getT(locale);
const { Content } = await render(entry);

// С завершающим слешем — совпадает с финальным URL (Cloudflare) и sitemap,
// чтобы canonical не указывал на 308-редирект.
const path = (loc: string, s: string) => (loc === 'ru' ? `/blog/${s}/` : `/${loc}/blog/${s}/`);
const canonical = new URL(path(locale, slug), Astro.site).href;
const homeHref = locale === 'ru' ? Astro.site!.href : new URL(`/${locale}/`, Astro.site).href;

// Переводы той же статьи (общий slug) → hreflang-альтернативы.
const all = await getCollection('articles');
const alternates = all
  .filter((a) => a.data.urlSlug === slug)
  .map((a) => ({ hreflang: a.data.locale, href: new URL(path(a.data.locale, a.data.urlSlug), Astro.site).href }));

// Перекрёстные ссылки: для каждой темы — 3 релевантные статьи той же локали.
const RELATED: Record<string, string[]> = {
  'insurance-for-residency-visa': [
    'copay-or-no-copay',
    'digital-nomad-visa-insurance',
    'private-healthcare-tenerife',
  ],
  'digital-nomad-visa-insurance': [
    'insurance-for-residency-visa',
    'copay-or-no-copay',
    'autonomo-business-insurance',
  ],
  'private-healthcare-tenerife': [
    'insurance-for-residency-visa',
    'family-insurance-tenerife',
    'copay-or-no-copay',
  ],
  'copay-or-no-copay': [
    'insurance-for-residency-visa',
    'private-healthcare-tenerife',
    'family-insurance-tenerife',
  ],
  'family-insurance-tenerife': [
    'insurance-for-residency-visa',
    'private-healthcare-tenerife',
    'copay-or-no-copay',
  ],
  'autonomo-business-insurance': [
    'insurance-for-residency-visa',
    'digital-nomad-visa-insurance',
    'copay-or-no-copay',
  ],
};
const related = (RELATED[slug] ?? [])
  .map((rs) => all.find((a) => a.data.locale === locale && a.data.urlSlug === rs))
  .filter((a): a is (typeof all)[number] => Boolean(a));

const logo = new URL('favicon.svg', Astro.site).href;
const ogImage = new URL('og-image.png', Astro.site).href;

const blogPosting = {
  '@type': 'BlogPosting',
  headline: title,
  description,
  inLanguage: locale,
  datePublished: date.toISOString(),
  dateModified: (updated ?? date).toISOString(),
  image: ogImage,
  mainEntityOfPage: canonical,
  author: { '@type': 'Organization', name: 'Seguro Tenerife' },
  publisher: {
    '@type': 'Organization',
    name: 'Seguro Tenerife',
    logo: { '@type': 'ImageObject', url: logo },
  },
};
const breadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Seguro Tenerife', item: homeHref },
    { '@type': 'ListItem', position: 2, name: t('blog_title'), item: `${homeHref}#articles` },
    { '@type': 'ListItem', position: 3, name: title, item: canonical },
  ],
};
const faqSchema = faq?.length
  ? {
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
const extraSchema = [blogPosting, breadcrumb, ...(faqSchema ? [faqSchema] : [])];

const fmtDate = (updated ?? date).toLocaleDateString(
  locale === 'uk' ? 'uk-UA' : locale === 'en' ? 'en-GB' : locale === 'es' ? 'es-ES' : 'ru-RU',
  { year: 'numeric', month: 'long', day: 'numeric' },
);

// Ссылки «поделиться» (URL-based, без JS-SDK).
const shareUrl = encodeURIComponent(canonical);
const shareText = encodeURIComponent(title);
const share = {
  whatsapp: `https://wa.me/?text=${encodeURIComponent(`${title} ${canonical}`)}`,
  telegram: `https://t.me/share/url?url=${shareUrl}&text=${shareText}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`,
  x: `https://twitter.com/intent/tweet?url=${shareUrl}&text=${shareText}`,
};
---

<Layout
  locale={locale}
  title={`${title} | Seguro Tenerife`}
  description={description}
  keywords={keywords}
  canonicalUrl={canonical}
  ogType="article"
  includeSiteFaq={false}
  extraSchema={extraSchema}
  alternates={alternates}
>
  <div id="top">
    <NavBar locale={locale} />
    <main class="bg-white">
      <article class="mx-auto w-[min(760px,calc(100vw-40px))] py-12">
        <nav class="mb-4 text-[0.82rem] text-muted" aria-label="breadcrumb">
          <a href={homeHref} class="hover:text-brand-dark">Seguro Tenerife</a>
          <span class="mx-1.5">/</span>
          <a href={`${homeHref}#articles`} class="hover:text-brand-dark">{t('blog_title')}</a>
        </nav>
        <span class="text-[0.76rem] font-bold uppercase tracking-wider text-brand-dark">{tag}</span>
        <h1 class="mt-2 font-heading text-[1.9rem] font-bold leading-tight text-ink sm:text-[2.3rem]">
          {title}
        </h1>
        <p class="mt-2 text-[0.84rem] text-muted">{fmtDate}</p>

        <div class="article-body mt-7">
          <Content />
        </div>

        <!-- Поделиться. -->
        <div class="mt-8 flex flex-wrap items-center gap-2 border-t border-slate-200 pt-5">
          <span class="mr-1 text-[0.85rem] font-semibold text-muted">{t('share_label')}</span>
          <a
            href={share.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="grid h-9 w-9 place-items-center rounded-full border border-slate-200 text-slate-600 transition-colors hover:border-brand hover:text-brand-dark"
          >
            <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.7 14.9L2 22l5.3-1.4A10 10 0 1 0 12 2Zm5.5 14c-.2.7-1.4 1.3-2 1.4-.5.1-1.1.1-1.8-.1-.4-.1-1-.3-1.6-.6-2.9-1.3-4.8-4.2-5-4.4-.1-.2-1.1-1.5-1.1-2.9 0-1.4.7-2 1-2.3.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 1.9c.1.2.1.4 0 .5l-.3.5-.4.4c-.1.1-.3.3-.1.5.1.3.7 1.1 1.4 1.8 1 .8 1.7 1.1 2 1.2.2.1.4.1.5-.1l.6-.7c.2-.2.3-.2.6-.1l1.8.9c.2.1.4.2.5.3 0 .2 0 .8-.2 1.4Z"/></svg>
          </a>
          <a
            href={share.telegram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Telegram"
            class="grid h-9 w-9 place-items-center rounded-full border border-slate-200 text-slate-600 transition-colors hover:border-brand hover:text-brand-dark"
          >
            <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21.9 4.3 18.7 19c-.2 1-.9 1.3-1.7.8l-4.6-3.4-2.2 2.1c-.2.2-.5.5-.9.5l.3-4.6 8.4-7.6c.4-.3-.1-.5-.6-.2L7.3 13 2.8 11.6c-1-.3-1-1 .2-1.5l17-6.6c.8-.3 1.5.2 1.2 1.5Z"/></svg>
          </a>
          <a
            href={share.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="grid h-9 w-9 place-items-center rounded-full border border-slate-200 text-slate-600 transition-colors hover:border-brand hover:text-brand-dark"
          >
            <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.3-1.5 1.6-1.5h1.6V3.6c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.4-4 4.1v2.3H7.5V13h2.8v8h3.2Z"/></svg>
          </a>
          <a
            href={share.x}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X"
            class="grid h-9 w-9 place-items-center rounded-full border border-slate-200 text-slate-600 transition-colors hover:border-brand hover:text-brand-dark"
          >
            <svg class="h-[16px] w-[16px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.2 2H21l-6.6 7.6L22 22h-6.8l-4.3-5.6L5.9 22H3l7-8.1L2.3 2H9l3.9 5.1L18.2 2Zm-1.2 18h1.5L7.1 3.9H5.5L17 20Z"/></svg>
          </a>
          <button
            type="button"
            data-share-copy={canonical}
            aria-label={t('share_copy')}
            class="grid h-9 w-9 place-items-center rounded-full border border-slate-200 text-slate-600 transition-colors hover:border-brand hover:text-brand-dark"
          >
            <svg class="h-[17px] w-[17px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7 0l2-2a5 5 0 0 0-7-7l-1 1" stroke-linecap="round"/><path d="M14 11a5 5 0 0 0-7 0l-2 2a5 5 0 0 0 7 7l1-1" stroke-linecap="round"/></svg>
          </button>
        </div>

        <script is:inline>
          document.querySelectorAll('[data-share-copy]').forEach((b) => {
            b.addEventListener('click', async () => {
              try {
                await navigator.clipboard.writeText(b.getAttribute('data-share-copy'));
                b.classList.add('!border-brand', '!text-brand-dark');
                setTimeout(() => b.classList.remove('!border-brand', '!text-brand-dark'), 1500);
              } catch {
                /* буфер недоступен */
              }
            });
          });
        </script>

        {
          faq && faq.length > 0 && (
            <section class="mt-10">
              <h2 class="font-heading text-[1.4rem] font-bold text-ink">{t('faq_h2')}</h2>
              <div class="mt-4 flex flex-col gap-3">
                {faq.map((f) => (
                  <details class="rounded-xl border border-slate-200 bg-bg p-4">
                    <summary class="cursor-pointer font-semibold text-ink">{f.q}</summary>
                    <p class="mt-2 text-[0.95rem] leading-relaxed text-muted">{f.a}</p>
                  </details>
                ))}
              </div>
            </section>
          )
        }

        {
          related.length > 0 && (
            <section class="mt-10">
              <h2 class="font-heading text-[1.4rem] font-bold text-ink">{t('art_related')}</h2>
              <div class="mt-4 grid gap-3 sm:grid-cols-2">
                {related.map((r) => (
                  <a
                    href={path(locale, r.data.urlSlug)}
                    class="flex flex-col gap-1.5 rounded-xl border border-slate-200 bg-bg p-4 transition-colors hover:border-brand focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
                  >
                    <span class="text-[0.72rem] font-bold uppercase tracking-wider text-brand-dark">
                      {r.data.tag}
                    </span>
                    <span class="font-heading text-[1.02rem] font-semibold leading-snug text-ink">
                      {r.data.title}
                    </span>
                  </a>
                ))}
              </div>
            </section>
          )
        }

        <!-- CTA: открыть чат-консультанта (мост seguro:ui → остров). -->
        <aside class="mt-10 rounded-2xl bg-gradient-to-br from-brand-dark to-brand p-6 text-white">
          <h2 class="font-heading text-[1.25rem] font-bold">{t('art_cta_h')}</h2>
          <p class="mt-1.5 text-[0.95rem] opacity-90">{t('art_cta_p')}</p>
          <button
            type="button"
            data-ui="open-chat"
            class="mt-4 inline-flex items-center gap-2 rounded-xl bg-white px-5 py-3 text-[0.95rem] font-semibold text-brand-dark transition-transform hover:scale-[1.02]"
          >
            {t('art_cta_btn')}
          </button>
        </aside>
      </article>
    </main>
    <Footer locale={locale} />
  </div>
  <Overlays client:only="react" locale={locale} />
</Layout>

<style>
  .article-body :global(h2) {
    font-family: var(--font-heading, inherit);
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 1.8rem 0 0.7rem;
    color: #0f172a;
  }
  .article-body :global(h3) {
    font-size: 1.12rem;
    font-weight: 700;
    margin: 1.3rem 0 0.5rem;
    color: #0f172a;
  }
  .article-body :global(p) {
    margin: 0.7rem 0;
    line-height: 1.7;
    color: #334155;
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0.7rem 0;
    padding-left: 1.3rem;
    line-height: 1.7;
    color: #334155;
  }
  .article-body :global(li) {
    margin: 0.3rem 0;
  }
  .article-body :global(strong) {
    color: #0f172a;
  }
  .article-body :global(a) {
    color: #0f766e;
    text-decoration: underline;
  }
  .article-body :global(blockquote) {
    margin: 1rem 0;
    border-left: 3px solid #0d9488;
    background: #f0fdfa;
    padding: 0.8rem 1rem;
    border-radius: 0 0.5rem 0.5rem 0;
    color: #0f172a;
  }
</style>
