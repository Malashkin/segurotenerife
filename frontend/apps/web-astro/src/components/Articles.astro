---
/** Секция «Статьи и гайды»: 6 карточек. Если для локали есть опубликованная
    статья (Content Layer) — карточка кликабельна и ведёт на /blog/<slug>; иначе
    остаётся пометка «Скоро». */
import SectionHead from './SectionHead.astro';
import { getCollection } from 'astro:content';
import { getT } from '../i18n/t';
import type { AppLocale } from '@shared/i18n';

const { locale } = Astro.props as { locale: AppLocale };
const t = getT(locale);

// Соответствие карточек (a1..a6) и slug'ов статей.
const ARTICLES = [
  { tagKey: 'a1_tag', titleKey: 'a1_t', descKey: 'a1_p', slug: 'insurance-for-residency-visa' },
  { tagKey: 'a2_tag', titleKey: 'a2_t', descKey: 'a2_p', slug: 'digital-nomad-visa-insurance' },
  { tagKey: 'a3_tag', titleKey: 'a3_t', descKey: 'a3_p', slug: 'private-healthcare-tenerife' },
  { tagKey: 'a4_tag', titleKey: 'a4_t', descKey: 'a4_p', slug: 'copay-or-no-copay' },
  { tagKey: 'a5_tag', titleKey: 'a5_t', descKey: 'a5_p', slug: 'family-insurance-tenerife' },
  { tagKey: 'a6_tag', titleKey: 'a6_t', descKey: 'a6_p', slug: 'autonomo-business-insurance' },
];

const published = await getCollection('articles', (a) => a.data.locale === locale);
const have = new Set(published.map((a) => a.data.urlSlug));
const hrefFor = (slug: string) =>
  locale === 'ru' ? `/blog/${slug}/` : `/${locale}/blog/${slug}/`;
---

<section id="articles" data-section="articles" class="bg-gradient-to-b from-white to-brand-tint2 py-16">
  <div class="mx-auto w-[min(1160px,calc(100vw-40px))]">
    <SectionHead eyebrow={t('art_eyebrow')} title={t('art_h2')} subtitle={t('art_p')} />
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        ARTICLES.map((article) => {
          const live = have.has(article.slug);
          const inner = (
            <>
              <span aria-hidden class="h-2 bg-gradient-to-r from-brand to-sky" />
              <div class="flex flex-1 flex-col gap-2.5 p-[22px]">
                <span class="text-[0.76rem] font-bold uppercase tracking-wider text-brand-dark">
                  {t(article.tagKey)}
                </span>
                <h3 class="font-heading text-[1.12rem] font-bold text-ink">{t(article.titleKey)}</h3>
                <p class="text-[0.92rem] text-muted">{t(article.descKey)}</p>
                {live ? (
                  <span class="mt-auto inline-flex w-fit items-center gap-1.5 text-[0.85rem] font-bold text-brand-dark">
                    {t('art_read')} →
                  </span>
                ) : (
                  <span class="mt-auto inline-flex w-fit items-center gap-1.5 rounded-full bg-slate-100 px-2.5 py-1 text-[0.78rem] font-semibold text-slate-500">
                    {t('art_soon')}
                  </span>
                )}
              </div>
            </>
          );
          return live ? (
            <a
              href={hrefFor(article.slug)}
              class="flex flex-col overflow-hidden rounded-card border border-slate-200 bg-white shadow-sm transition-shadow hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
            >
              {inner}
            </a>
          ) : (
            <article class="flex flex-col overflow-hidden rounded-card border border-slate-200 bg-white shadow-sm">
              {inner}
            </article>
          );
        })
      }
    </div>
    <div class="mt-8 text-center">
      <a
        href={locale === 'ru' ? '/blog/' : `/${locale}/blog/`}
        class="inline-flex items-center gap-1.5 rounded-xl border border-slate-200 bg-white px-5 py-2.5 text-[0.9rem] font-semibold text-brand-dark transition-colors hover:border-brand"
      >
        {t('art_all')} →
      </a>
    </div>
  </div>
</section>
