---
/**
 * Хаб блога: /blog/ (ru) и /<locale>/blog/ — листинг всех статей локали.
 * Внутренний хаб усиливает SEO (Google любит такие страницы-сборники) и
 * удержание. Разметка ItemList + BreadcrumbList, hreflang на хабы других языков.
 */
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import NavBar from './NavBar.astro';
import Footer from './Footer.astro';
import SectionHead from './SectionHead.astro';
import Overlays from '../islands/Overlays.tsx';
import { getT } from '../i18n/t';
import type { AppLocale } from '@shared/i18n';

const { locale } = Astro.props as { locale: AppLocale };
const t = getT(locale);

const LOCALES: AppLocale[] = ['ru', 'en', 'es', 'uk'];
const hubPath = (l: string) => (l === 'ru' ? '/blog/' : `/${l}/blog/`);
const artPath = (s: string) => (locale === 'ru' ? `/blog/${s}/` : `/${locale}/blog/${s}/`);

const arts = (await getCollection('articles', (a) => a.data.locale === locale)).sort(
  (a, b) => a.data.order - b.data.order,
);

const canonical = new URL(hubPath(locale), Astro.site).href;
const homeHref = locale === 'ru' ? Astro.site!.href : new URL(`/${locale}/`, Astro.site).href;
const alternates = LOCALES.map((l) => ({ hreflang: l, href: new URL(hubPath(l), Astro.site).href }));

const itemList = {
  '@type': 'ItemList',
  itemListElement: arts.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: new URL(artPath(a.data.urlSlug), Astro.site).href,
    name: a.data.title,
  })),
};
const breadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Seguro Tenerife', item: homeHref },
    { '@type': 'ListItem', position: 2, name: t('blog_title'), item: canonical },
  ],
};
---

<Layout
  locale={locale}
  title={`${t('blog_title')} — Seguro Tenerife`}
  description={t('blog_meta_desc')}
  keywords={t('blog_meta_kw')}
  canonicalUrl={canonical}
  includeSiteFaq={false}
  extraSchema={[itemList, breadcrumb]}
  alternates={alternates}
>
  <div id="top">
    <NavBar locale={locale} />
    <main class="bg-gradient-to-b from-white to-brand-tint2 py-14">
      <div class="mx-auto w-[min(1160px,calc(100vw-40px))]">
        <SectionHead eyebrow={t('art_eyebrow')} title={t('blog_title')} subtitle={t('blog_meta_desc')} />
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {
            arts.map((a) => (
              <a
                href={artPath(a.data.urlSlug)}
                class="flex flex-col overflow-hidden rounded-card border border-slate-200 bg-white shadow-sm transition-shadow hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
              >
                <span aria-hidden class="h-2 bg-gradient-to-r from-brand to-sky" />
                <div class="flex flex-1 flex-col gap-2.5 p-[22px]">
                  <span class="text-[0.76rem] font-bold uppercase tracking-wider text-brand-dark">
                    {a.data.tag}
                  </span>
                  <h2 class="font-heading text-[1.12rem] font-bold text-ink">{a.data.title}</h2>
                  <p class="text-[0.92rem] text-muted">{a.data.description}</p>
                  <span class="mt-auto inline-flex w-fit items-center gap-1.5 text-[0.85rem] font-bold text-brand-dark">
                    {t('art_read')} →
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </main>
    <Footer locale={locale} />
  </div>
  <Overlays client:only="react" locale={locale} />
</Layout>
