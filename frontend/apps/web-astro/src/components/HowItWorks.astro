---
/** Секция «Как проходит подбор» — 4 шага (порт HowItWorks). */
import SectionHead from './SectionHead.astro';
import { getT } from '../i18n/t';
import type { AppLocale } from '@shared/i18n';

const { locale } = Astro.props as { locale: AppLocale };
const t = getT(locale);

const STEPS = [
  { n: '01', titleKey: 'hw1_t', descKey: 'hw1_p' },
  { n: '02', titleKey: 'hw2_t', descKey: 'hw2_p' },
  { n: '03', titleKey: 'hw3_t', descKey: 'hw3_p' },
  { n: '04', titleKey: 'hw4_t', descKey: 'hw4_p' },
];
---

<section id="how" data-section="how" class="bg-gradient-to-b from-brand-tint2 to-white py-16">
  <div class="mx-auto w-[min(1160px,calc(100vw-40px))]">
    <SectionHead eyebrow={t('how_eyebrow')} title={t('how_h2')} subtitle={t('how_p')} centered />
    <ol class="grid grid-cols-1 gap-[18px] sm:grid-cols-2 lg:grid-cols-4">
      {
        STEPS.map((step) => (
          <li class="rounded-card border border-slate-200 bg-white p-6 shadow-sm">
            <div class="font-heading text-2xl font-extrabold text-brand">{step.n}</div>
            <h3 class="mb-1.5 mt-2.5 font-heading text-[1.08rem] font-bold text-ink">
              {t(step.titleKey)}
            </h3>
            <p class="text-[0.92rem] text-muted">{t(step.descKey)}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
