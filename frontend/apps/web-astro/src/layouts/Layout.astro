---
/**
 * Базовый layout лендинга: <head> со всей SEO-разметкой per-locale.
 *
 * title/description приходят пропами (локализованы на странице), а hreflang,
 * canonical, OG/Twitter и JSON-LD (Organization + WebSite + FAQPage) строятся
 * здесь из локали и общих словарей. Тело — <slot/> (секции лендинга).
 */
import '../styles/global.css';
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import { dictFor } from '../i18n/t';
import type { AppLocale } from '@shared/i18n';

interface Props {
  locale: AppLocale;
  title: string;
  description: string;
  /** SEO-ключевые слова (целевые запросы + варианты написания). Опц. */
  keywords?: string;
}
const { locale, title, description, keywords } = Astro.props;

// Код верификации Google Search Console (из env, без правки кода). Если задан —
// добавим <meta name="google-site-verification">.
const googleVerify = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION as string | undefined;

const LOCALES: AppLocale[] = ['ru', 'en', 'es', 'uk'];
const OG_LOCALE: Record<AppLocale, string> = {
  ru: 'ru_RU',
  en: 'en_US',
  es: 'es_ES',
  uk: 'uk_UA',
};

const canonical = getAbsoluteLocaleUrl(locale, '/');
const ogImage = new URL('og-image.png', Astro.site).href;

// FAQPage JSON-LD из словаря локали (faq1..faq6) — для rich-результатов.
const d = dictFor(locale);
const faqItems = [1, 2, 3, 4, 5, 6]
  .map((i) => ({ q: d[`faq${i}_q`], a: d[`faq${i}_a`] }))
  .filter((x) => x.q && x.a)
  .map((x) => ({
    '@type': 'Question',
    name: x.q,
    acceptedAnswer: { '@type': 'Answer', text: x.a },
  }));

const jsonld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      // InsuranceAgency — сигнал локального бизнеса (помогает в локальном поиске
      // «страховка Тенерифе» и на картах).
      '@type': ['Organization', 'InsuranceAgency'],
      '@id': `${Astro.site}#org`,
      name: 'Seguro Tenerife',
      url: Astro.site?.href,
      logo: new URL('favicon.svg', Astro.site).href,
      image: ogImage,
      description,
      areaServed: [
        { '@type': 'Place', name: 'Tenerife' },
        { '@type': 'Place', name: 'Canary Islands' },
        { '@type': 'Country', name: 'Spain' },
      ],
      address: { '@type': 'PostalAddress', addressRegion: 'Canary Islands', addressCountry: 'ES' },
      knowsLanguage: ['ru', 'uk', 'es', 'en'],
    },
    {
      '@type': 'WebSite',
      '@id': `${Astro.site}#website`,
      url: Astro.site?.href,
      name: 'Seguro Tenerife',
      inLanguage: [locale],
    },
    { '@type': 'FAQPage', mainEntity: faqItems },
  ],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content="index, follow, max-image-preview:large" />
    {googleVerify && <meta name="google-site-verification" content={googleVerify} />}
    <link rel="canonical" href={canonical} />

    {LOCALES.map((l) => <link rel="alternate" hreflang={l} href={getAbsoluteLocaleUrl(l, '/')} />)}
    <link rel="alternate" hreflang="x-default" href={getAbsoluteLocaleUrl('ru', '/')} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0d9488" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Seguro Tenerife" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={OG_LOCALE[locale]} />
    {
      LOCALES.filter((l) => l !== locale).map((l) => (
        <meta property="og:locale:alternate" content={OG_LOCALE[l]} />
      ))
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonld)} />

    <!-- Язык по устройству: на корне `/` (RU по умолчанию) перенаправляем на язык
         браузера (es/uk/en), уважая явный выбор из localStorage. Раннее в <head>
         — чтобы редирект случился до отрисовки и без «мигания». -->
    <script is:inline>
      (function () {
        try {
          var p = location.pathname;
          if (p !== '/' && p !== '') return; // только корень
          var sup = ['ru', 'es', 'uk', 'en'];
          var stored = null;
          try { stored = localStorage.getItem('seguro_lang'); } catch (e) {}
          if (stored && stored !== 'ru' && sup.indexOf(stored) !== -1) {
            location.replace('/' + stored + '/'); return;
          }
          if (!stored) {
            var nav = (navigator.language || '').slice(0, 2).toLowerCase();
            var map = { be: 'ru', ru: 'ru', uk: 'uk', en: 'en', es: 'es' };
            var t = map[nav];
            if (t && t !== 'ru') location.replace('/' + t + '/');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen bg-bg text-ink">
    <slot />

    <!-- Мост статичных кнопок → острова Overlays: делегированный клик по
         [data-ui] шлёт событие seguro:ui с данными кнопки (ui/intent/doc). -->
    <script>
      document.addEventListener('click', (e) => {
        const el = (e.target as HTMLElement | null)?.closest<HTMLElement>('[data-ui]');
        if (!el) return;
        window.dispatchEvent(new CustomEvent('seguro:ui', { detail: { ...el.dataset } }));
      });

      // Запоминаем явный выбор языка (клик по переключателю) — чтобы корень `/`
      // уважал его и не редиректил по языку браузера.
      document.addEventListener('click', (e) => {
        const a = (e.target as HTMLElement | null)?.closest<HTMLElement>('[data-setlang]');
        if (!a) return;
        const to = a.dataset.setlang as string;
        try {
          localStorage.setItem('seguro_lang', to);
        } catch {
          /* приватный режим — игнор */
        }
        // Явная смена языка → в аналитику (seguro:track → PostHog, gated).
        window.dispatchEvent(
          new CustomEvent('seguro:track', { detail: { event: 'lang_switched', props: { to } } }),
        );
      });
    </script>

    <!-- Доп. продуктовая аналитика статичной страницы: глубина скролла, просмотры
         секций (IntersectionObserver) и открытия FAQ. Шлём через канал
         seguro:track → остров Overlays проксирует в PostHog (gated на согласие). -->
    <script>
      const track = (event: string, props?: Record<string, unknown>) =>
        window.dispatchEvent(new CustomEvent('seguro:track', { detail: { event, props } }));

      // Глубина скролла: 25/50/75/100% — каждый порог один раз.
      const marks = [25, 50, 75, 100];
      const fired = new Set<number>();
      const onScroll = () => {
        const doc = document.documentElement;
        const max = doc.scrollHeight - doc.clientHeight;
        if (max <= 0) return;
        const pct = (doc.scrollTop / max) * 100;
        for (const m of marks) {
          if (pct >= m && !fired.has(m)) {
            fired.add(m);
            track('scroll_depth', { percent: m });
          }
        }
        if (fired.size === marks.length) window.removeEventListener('scroll', onScroll);
      };
      window.addEventListener('scroll', onScroll, { passive: true });

      // Просмотры секций: фиксируем первый показ каждой [data-section].
      const seen = new Set<string>();
      const io = new IntersectionObserver(
        (entries) => {
          for (const en of entries) {
            const name = (en.target as HTMLElement).dataset.section;
            if (en.isIntersecting && name && !seen.has(name)) {
              seen.add(name);
              track('section_viewed', { section: name });
            }
          }
        },
        { threshold: 0.4 },
      );
      document.querySelectorAll('[data-section]').forEach((el) => io.observe(el));

      // Открытие пунктов FAQ.
      document.querySelectorAll('details[data-faq]').forEach((d) => {
        d.addEventListener('toggle', () => {
          if ((d as HTMLDetailsElement).open) {
            track('faq_opened', { q: (d as HTMLElement).dataset.faq });
          }
        });
      });
    </script>
  </body>
</html>
